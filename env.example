# Token do bot do Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Caminho secreto do webhook (incluir barra inicial, ex: /tg-hook-abc123)
TELEGRAM_WEBHOOK_SECRET=/telegram-webhook-secret

# URL do seu app na Vercel (após deploy)
APP_URL=https://seu-projeto.vercel.app

# Chave PIX que irá receber os pagamentos
MY_PIX_KEY=seu_email@exemplo.com.br

# Configurações opcionais
DEFAULT_CURRENCY=BRL
DEFAULT_LOCALE=pt-BR

# URL base para entrega de links/arquivos (opcional)
DELIVERY_BASE_URL=https://storage-ou-linkbase/

# Chat ID do operador para receber notificações de comprovantes
OPERATOR_CHAT_ID=123456789

# Senha secreta para proteger endpoint de trigger-delivery (opcional)
TRIGGER_SECRET=uma_senha_secreta_forte

